# ── Database ───────────────────────────────────────────────────────────────
# LOCAL (local Postgres — install Postgres on your PC for local dev):
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/applyt
# PRODUCTION (copy from Neon dashboard → Connection Details → Connection string):
# DATABASE_URL=postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
# Production: ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Frontend URL (used in follow-up reminder email links) ──────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://your-app.vercel.app

# ── Firebase Admin SDK ─────────────────────────────────────────────────────
# Option A — paste full JSON string (best for Render):
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B — path to JSON file (easier for local dev):
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

# ── Email Reminders (Gmail) ────────────────────────────────────────────────
# 1. Enable 2-Step Verification at myaccount.google.com/security
# 2. Search "App passwords" → create one named "Applyt" → copy 16-char code
GMAIL_SENDER=banabookids2707@gmail.com
GMAIL_PASSWORD=Siddharthnalini@123
